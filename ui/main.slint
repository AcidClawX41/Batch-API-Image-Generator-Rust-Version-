// ui/main.slint — Batch Image Generator (Rust + Slint)
// Responsive layout — adapts from ~600px height upward

import { Button, LineEdit, ComboBox, CheckBox, SpinBox, TextEdit,
         GroupBox, ProgressIndicator, VerticalBox, HorizontalBox,
         ScrollView, Slider, StandardButton } from "std-widgets.slint";

// ─── Color palette ───
global Theme {
    out property <color> bg: #0d0d0d;
    out property <color> surface: #1a1a1a;
    out property <color> border: #2a2a2a;
    out property <color> text: #e0e0e0;
    out property <color> text-dim: #888888;
    out property <color> accent: #5b8cd4;
    out property <color> green: #6fcf6f;
    out property <color> red: #cf6f6f;
    out property <color> purple: #b08cdf;
    out property <color> cyan: #8ccfdf;
    out property <color> yellow: #f0c674;
}

export component MainWindow inherits Window {
    title: "Batch Image Generator v1 (Rust)";
    min-width: 620px;
    min-height: 580px;
    preferred-width: 880px;
    preferred-height: 1080px;
    background: Theme.bg;
    icon: @image-url("../icons/xai_generator.png");

    // ─── Properties (bound from Rust) ───
    in-out property <string> api-key;
    in-out property <string> prompt-base;
    in-out property <string> preview-text;
    in-out property <string> log-text;
    in-out property <string> output-folder;
    in-out property <string> status-text: "● DETENIDO";
    in-out property <color> status-color: Theme.text-dim;
    in-out property <string> countdown-text: "--:--";
    in-out property <int> generation-count: 0;
    in-out property <float> progress-value: 0;
    in-out property <bool> progress-indeterminate: false;
    in-out property <string> progress-label: "Esperando...";

    // Mode selector
    in-out property <int> current-mode: 0; // 0=A, 1=B

    // Model
    in-out property <int> model-index: 0;
    in-out property <[string]> model-list: [
        "xAI — grok-imagine-image",
        "xAI — grok-imagine-image-pro",
        "Google — gemini-2.5-flash-image (Nano Banana)",
        "Google — gemini-3-pro-image-preview (Nano Banana Pro)",
        "OpenAI — gpt-image-1.5",
        "OpenAI — gpt-image-1",
        "OpenAI — gpt-image-1-mini",
        "OpenAI — dall-e-3 (legacy)"
    ];

    // Theme presets for Mode B
    in-out property <int> theme-index: 0;
    in-out property <[string]> theme-list: [
        "Tsundere School", "Cyberpunk", "Gothic",
        "Miko / Shrine", "Casual Modern", "🎲 Full Random"
    ];

    // Interval
    in-out property <int> interval-secs: 60;

    // Randomizer state (Mode A)
    in-out property <bool> rand-active: false;
    in-out property <bool> chk-nails: true;
    in-out property <bool> chk-orient: true;
    in-out property <bool> chk-expression: false;
    in-out property <bool> chk-outfit: false;
    in-out property <bool> chk-legwear: false;
    in-out property <bool> chk-environment: false;
    in-out property <bool> chk-atmosphere: false;
    in-out property <bool> chk-pose: false;
    in-out property <bool> chk-lighting: false;
    in-out property <bool> chk-camera: false;
    in-out property <bool> chk-rare: false;

    // New randomizer pools (Mode A)
    in-out property <bool> chk-accessories: false;
    in-out property <bool> chk-makeup: false;
    in-out property <bool> chk-body-type: false;
    in-out property <bool> chk-age-vibe: false;
    in-out property <bool> chk-color-palette: false;
    in-out property <bool> chk-time-of-day: false;
    in-out property <bool> chk-weather: false;
    in-out property <bool> chk-bg-props: false;
    in-out property <bool> chk-material: false;
    in-out property <bool> chk-motion: false;

    // Mode B options
    in-out property <bool> chk-curated: false;
    in-out property <bool> chk-auto-b: true;

    // Running state
    in-out property <bool> is-running: false;
    in-out property <bool> key-visible: false;

    // ─── Callbacks (handled in Rust) ───
    callback start-loop();
    callback stop-loop();
    callback single-generate();
    callback toggle-randomizer();
    callback gen-preview-b();
    callback browse-folder();

    // ─── Main scrollable area ───
    ScrollView {
        VerticalBox {
            padding: 14px;
            spacing: 8px;

            // ── Header ──
            HorizontalBox {
                alignment: space-between;
                Text {
                    text: "⚡ Batch Image Generator v1";
                    font-size: 17px;
                    font-weight: 700;
                    color: white;
                    vertical-alignment: center;
                }
                Rectangle {
                    background: Theme.surface;
                    border-color: Theme.border;
                    border-width: 1px;
                    border-radius: 4px;
                    width: 120px;
                    height: 26px;
                    Text {
                        text: root.status-text;
                        color: root.status-color;
                        font-size: 11px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // ── API Key ──
            GroupBox {
                title: "API Key del proveedor";
                HorizontalBox {
                    spacing: 8px;
                    LineEdit {
                        text <=> root.api-key;
                        placeholder-text: "Pega aquí la API key del modelo seleccionado";
                        input-type: root.key-visible ? InputType.text : InputType.password;
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: root.key-visible ? "🔒" : "👁";
                        max-width: 40px;
                        clicked => {
                            root.key-visible = !root.key-visible;
                        }
                    }
                }
            }

            // ── Mode selector ──
            HorizontalBox {
                spacing: 8px;
                alignment: start;
                Text {
                    text: "Modo:";
                    color: Theme.text-dim;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                ComboBox {
                    model: ["A — Prompt manual + randomizer", "B — Prompt auto-generado (pools)"];
                    current-index <=> root.current-mode;
                    horizontal-stretch: 1;
                    min-width: 250px;
                }
            }

            // ── MODE A: Manual prompt + randomizer ──
            if root.current-mode == 0 : VerticalBox {
                spacing: 6px;

                GroupBox {
                    title: "Prompt (base)";
                    TextEdit {
                        text <=> root.prompt-base;
                        min-height: 60px;
                        vertical-stretch: 1;
                    }
                }

                GroupBox {
                    title: "🎲 Randomizer (Mode A)";

                    VerticalBox {
                        spacing: 5px;

                        // Toggle button
                        HorizontalBox {
                            Button {
                                text: root.rand-active ? "🎲  Aleatorio: ON" : "🎲  Aleatorio: OFF";
                                min-height: 30px;
                                clicked => { root.toggle-randomizer(); }
                            }
                        }

                        // Row 1: Replace operations
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Text { text: "Reemplazar:"; color: Theme.text-dim; font-size: 11px; vertical-alignment: center; width: 80px; }
                            CheckBox { text: "Uñas"; checked <=> root.chk-nails; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Orientación"; checked <=> root.chk-orient; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Expresión"; checked <=> root.chk-expression; enabled: root.rand-active; width: 140px; }
                        }

                        // Row 2: Inject operations
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Text { text: "Inyectar:"; color: Theme.text-dim; font-size: 11px; vertical-alignment: center; width: 80px; }
                            CheckBox { text: "Ropa"; checked <=> root.chk-outfit; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Medias"; checked <=> root.chk-legwear; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Escenario"; checked <=> root.chk-environment; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Atmósfera"; checked <=> root.chk-atmosphere; enabled: root.rand-active; width: 140px; }
                        }

                        // Row 3: More inject
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Rectangle { width: 80px; }
                            CheckBox { text: "Pose"; checked <=> root.chk-pose; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Luz"; checked <=> root.chk-lighting; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Cámara"; checked <=> root.chk-camera; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Detalles Raros"; checked <=> root.chk-rare; enabled: root.rand-active; width: 140px; }
                        }

                        // Row 4: Character extras
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Text { text: "Personaje:"; color: Theme.text-dim; font-size: 11px; vertical-alignment: center; width: 80px; }
                            CheckBox { text: "Accesorios"; checked <=> root.chk-accessories; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Maquillaje"; checked <=> root.chk-makeup; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Silueta"; checked <=> root.chk-body-type; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Edad"; checked <=> root.chk-age-vibe; enabled: root.rand-active; width: 140px; }
                        }

                        // Row 5: Scene extras
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Text { text: "Escena:"; color: Theme.text-dim; font-size: 11px; vertical-alignment: center; width: 80px; }
                            CheckBox { text: "Paleta color"; checked <=> root.chk-color-palette; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Hora del día"; checked <=> root.chk-time-of-day; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Clima"; checked <=> root.chk-weather; enabled: root.rand-active; width: 140px; }
                        }

                        // Row 6: Detail extras
                        HorizontalBox {
                            spacing: 0px;
                            alignment: start;
                            Rectangle { width: 80px; }
                            CheckBox { text: "Props fondo"; checked <=> root.chk-bg-props; enabled: root.rand-active; width: 120px; }
                            CheckBox { text: "Material"; checked <=> root.chk-material; enabled: root.rand-active; width: 140px; }
                            CheckBox { text: "Movimiento"; checked <=> root.chk-motion; enabled: root.rand-active; width: 140px; }
                        }
                    }
                }
            }

            // ── MODE B: Auto-generated prompt ──
            if root.current-mode == 1 : GroupBox {
                title: "🎰 Auto-Generador (Mode B)";

                VerticalBox {
                    spacing: 8px;

                    HorizontalBox {
                        spacing: 10px;
                        Text { text: "Tema:"; color: Theme.text-dim; vertical-alignment: center; }
                        ComboBox {
                            model: root.theme-list;
                            current-index <=> root.theme-index;
                            horizontal-stretch: 1;
                            min-width: 180px;
                        }
                        CheckBox { text: "Combos curados"; checked <=> root.chk-curated; }
                    }

                    HorizontalBox {
                        spacing: 10px;
                        Button {
                            text: "🎰  Generar nuevo prompt";
                            min-height: 30px;
                            clicked => { root.gen-preview-b(); }
                        }
                        CheckBox { text: "Auto en loop"; checked <=> root.chk-auto-b; }
                    }
                }
            }

            // ── Preview ──
            GroupBox {
                title: "Preview del prompt";
                TextEdit {
                    text <=> root.preview-text;
                    read-only: true;
                    min-height: 50px;
                    vertical-stretch: 1;
                    wrap: word-wrap;
                }
            }

            // ── Configuration ──
            GroupBox {
                title: "Configuración";

                VerticalBox {
                    spacing: 6px;

                    // Row 1: Model + Interval
                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Modelo / proveedor:"; color: Theme.text-dim; vertical-alignment: center; }
                        ComboBox {
                            model: root.model-list;
                            current-index <=> root.model-index;
                            horizontal-stretch: 1;
                            min-width: 180px;
                        }
                        Text { text: "Intervalo:"; color: Theme.text-dim; vertical-alignment: center; }
                        SpinBox {
                            value <=> root.interval-secs;
                            minimum: 10;
                            maximum: 600;
                        }
                        Text { text: "seg"; color: Theme.text-dim; vertical-alignment: center; }
                    }

                    // Row 2: Output folder
                    HorizontalBox {
                        spacing: 8px;
                        Text { text: "Carpeta:"; color: Theme.text-dim; vertical-alignment: center; }
                        LineEdit {
                            text <=> root.output-folder;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "📂";
                            max-width: 40px;
                            clicked => { root.browse-folder(); }
                        }
                    }
                }
            }

            // ── Control buttons ──
            HorizontalBox {
                spacing: 10px;
                Button {
                    text: "▶  Iniciar";
                    enabled: !root.is-running;
                    min-height: 36px;
                    horizontal-stretch: 1;
                    clicked => { root.start-loop(); }
                }
                Button {
                    text: "■  Detener";
                    enabled: root.is-running;
                    min-height: 36px;
                    horizontal-stretch: 1;
                    clicked => { root.stop-loop(); }
                }
                Button {
                    text: "⚡ Generar 1";
                    enabled: !root.is-running;
                    min-height: 36px;
                    horizontal-stretch: 1;
                    clicked => { root.single-generate(); }
                }
            }

            // ── Progress ──
            HorizontalBox {
                spacing: 10px;
                ProgressIndicator {
                    progress: root.progress-indeterminate ? -1 : root.progress-value;
                    horizontal-stretch: 3;
                    min-height: 14px;
                }
                Text {
                    text: root.countdown-text;
                    color: Theme.accent;
                    font-size: 15px;
                    font-weight: 700;
                    min-width: 55px;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.generation-count;
                    color: Theme.accent;
                    font-size: 22px;
                    font-weight: 700;
                    min-width: 45px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "imgs";
                    color: Theme.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }

            // ── Log (debug) ──
            GroupBox {
                title: "Log";
                TextEdit {
                    text <=> root.log-text;
                    read-only: true;
                    min-height: 70px;
                    vertical-stretch: 2;
                    wrap: word-wrap;
                }
            }
        }
    }
}